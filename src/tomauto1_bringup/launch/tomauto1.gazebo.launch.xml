<launch>
    <let name="urdf_path" 
        value="$(find-pkg-share tomauto1_description)/urdf/tomauto1.urdf.xacro" />
    <let name="gazebo_config_path"
        value="$(find-pkg-share tomauto1_bringup)/config/gazebo_bridge.yaml" />
    <let name="rviz_config_path"
        value="$(find-pkg-share tomauto1_description)/rviz/nav2_lidar.rviz" />

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
            value="$(command 'xacro $(var urdf_path)')" />
        <param name="use_sim_time" value="true" />
    </node>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(find-pkg-share tomauto1_bringup)/worlds/dpt3.sdf -r" />
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <!-- ✅ Only ONE spawner for diff_drive_controller -->
<node pkg="controller_manager" exec="spawner" 
    args="diff_drive_controller --controller-manager /controller_manager">
    <remap from="/diff_drive_controller/odom" to="/odom" />
    <remap from="/diff_drive_controller/cmd_vel" to="/cmd_vel" />
</node>

    <node pkg="controller_manager" exec="spawner" 
        args="joint_state_broadcaster --controller-manager /controller_manager" />

    <node pkg="rviz2" exec="rviz2" output="screen" 
        args="-d $(var rviz_config_path)" />

    <!-- ✅ Relay /cmd_vel (Twist) to /diff_drive_controller/cmd_vel (TwistStamped) -->
    <node pkg="topic_tools" exec="relay" 
        args="/cmd_vel /diff_drive_controller/cmd_vel" />

<node pkg="twist_stamper" exec="twist_stamper" name="twist_stamper">
    <param name="frame_id" value="base_link" />
    <remap from="cmd_vel_in" to="/cmd_vel" />
    <remap from="cmd_vel_out" to="/diff_drive_controller/cmd_vel" />
</node>

    <include file="$(find-pkg-share nav2_bringup)/launch/bringup_launch.py">
        <arg name="map"
            value="/home/daniel/projects/foodlikeair/tomauto1/src/tomauto1_bringup/maps/dpt3/dpt3.yaml"/>
        <arg name="params_file"
            value="$(find-pkg-share tomauto1_bringup)/config/nav2_params.yaml"/>
        <arg name="use_sim_time" value="True"/>
    </include>

</launch>