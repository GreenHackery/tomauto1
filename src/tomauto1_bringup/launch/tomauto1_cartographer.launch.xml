<launch>
    <!-- 1. Define Paths and Variables -->
    <let name="urdf_path" 
         value="$(find-pkg-share tomauto1_description)/urdf/tomauto1.urdf.xacro" />
    <let name="gazebo_config_path"
         value="$(find-pkg-share tomauto1_bringup)/config/gazebo_bridge.yaml" />
    <let name="rviz_config_path"
         value="$(find-pkg-share tomauto1_description)/rviz/nav2_lidar.rviz" />

    <!-- 2. State Publisher (Publishes base_link -> base_scan) -->
    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
               value="$(command 'xacro $(var urdf_path)')" />
        <param name="use_sim_time" value="true" />
    </node>
    
    <!-- 3. Launch Simulation World -->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(find-pkg-share tomauto1_bringup)/worlds/dpt3.sdf -r" />
    </include>

    <!-- 4. DELAYED ROBOT SPAWNER 
         Forces a 5-second sleep to let Gazebo completely construct the world matrices first -->
    <executable cmd="sleep 5 &amp;&amp; ros2 run ros_gz_sim create -topic robot_description -name tomauto1 -x 0.0 -y -0.25 -z 0.05" output="screen" shell="true" />

    <!-- 5. Data Bridging -->
    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <!-- 6. Visualization -->
    <node pkg="rviz2" exec="rviz2" output="screen" 
          args="-d $(var rviz_config_path)" />

    <!-- 7. SLAM/Mapping Architecture -->
    <include file="$(find-pkg-share slam_toolbox)/launch/online_async_launch.py">
        <arg name="params_file" value="$(find-pkg-share tomauto1_bringup)/config/mapper_params_online_async.yaml" />
        <arg name="use_sim_time" value="true" />
    </include>

</launch>
